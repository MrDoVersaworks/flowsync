# ============================================================
# FLOWSYNC SOVEREIGN ENVIRONMENT TEMPLATE
# ============================================================

# SYSTEM
PORT=5000
NODE_ENV=development

# SECURITY
JWT_SECRET=your_sovereign_secret_here
REFRESH_TOKEN_SECRET=your_refresh_secret_here
ENCRYPTION_KEY=32_character_hex_key_here_for_aes_256

# DATABASE (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/flowsync

# AI (GEMINI)
# Paste your Gemini API Key here for the Inception Engine
GEMINI_API_KEY=your_gemini_api_key_here

# CLIENT
CLIENT_URL=http://localhost:3000
